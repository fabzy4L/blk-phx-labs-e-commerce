# BLK PHX LABS — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# ── SHOPIFY ──────────────────────────────────────────────
SHOPIFY_STORE_URL=https://your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_API_VERSION=2025-01
SHOPIFY_WEBHOOK_SECRET=

# ── KLAVIYO ──────────────────────────────────────────────
KLAVIYO_PRIVATE_API_KEY=
KLAVIYO_PUBLIC_API_KEY=
KLAVIYO_LIST_ID_MAIN=
KLAVIYO_LIST_ID_SUBSCRIBERS=

# ── RECHARGE ─────────────────────────────────────────────
RECHARGE_ACCESS_TOKEN=
RECHARGE_WEBHOOK_SECRET=

# ── SUPLIFUL ─────────────────────────────────────────────
SUPLIFUL_API_KEY=

# ── LLM PROVIDER ─────────────────────────────────────────
# 'google' = Gemini free tier (default, Phase 1 — $0/month)
# 'anthropic' = Claude Haiku (Phase 2+ — ~$0.001/inquiry)
LLM_PROVIDER=google

# ── GOOGLE AI STUDIO (FREE TIER) ──────────────────────────
# Get free key at: https://aistudio.google.com/apikey
# Free tier: 1,500 requests/day on Flash models
GOOGLE_AI_STUDIO_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash

# ── ANTHROPIC (PAID — PHASE 2+) ──────────────────────────
# Only needed when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── GOOGLE ANALYTICS ─────────────────────────────────────
GA4_PROPERTY_ID=
GA4_SERVICE_ACCOUNT_JSON_PATH=./credentials/ga4-service-account.json

# ── BUFFER ───────────────────────────────────────────────
BUFFER_ACCESS_TOKEN=
BUFFER_PROFILE_IDS_TIKTOK=
BUFFER_PROFILE_IDS_INSTAGRAM=
BUFFER_PROFILE_IDS_LINKEDIN=

# ── TYPEFORM ─────────────────────────────────────────────
TYPEFORM_API_TOKEN=
TYPEFORM_QUIZ_FORM_ID=
TYPEFORM_WEBHOOK_SECRET=

# ── DATABASE ─────────────────────────────────────────────
DATABASE_URL=sqlite:///./blkphx.db
# Prod: DATABASE_URL=postgresql://user:pass@host:5432/blkphx

# ── APP CONFIG ───────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
ALERT_EMAIL=your@email.com
DASHBOARD_PORT=8501

# ── WEBHOOK SERVER ───────────────────────────────────────
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8000
# Public URL used by scripts/setup_webhooks.py to register endpoints
# Local dev: run `ngrok http 8000` and paste the https:// URL here
# Production: your deployed service URL (Railway, Fly.io, etc.)
WEBHOOK_BASE_URL=https://your-domain.com

# ── SCHEDULER ────────────────────────────────────────────
# Pipeline runs daily at this UTC hour (0-23)
PIPELINE_SCHEDULE_HOUR=6
PIPELINE_SCHEDULE_MINUTE=0
# Content generation runs weekly on this day at this UTC hour
CONTENT_SCHEDULE_DAY=mon
CONTENT_SCHEDULE_HOUR=7
CONTENT_SCHEDULE_ENABLED=true

# ── SUPLIFUL VARIANT MAP ──────────────────────────────────
# JSON map of Shopify product SKU → Supliful variant ID
# Get Supliful variant IDs from your Supliful dashboard → Products
# Leave as {} to disable auto-fulfillment until IDs are confirmed
# Example: {"FOCUS-01": "sv_abc123", "RECOVERY-01": "sv_xyz789"}
SUPLIFUL_VARIANT_MAP={}

# ── CHURN DETECTION ───────────────────────────────────────
# Days without a paid order before customer is flagged as churn risk
CHURN_INACTIVE_DAYS=45
